{
  "name": "specman",
  "version": "0.1.5",
  "description": "AI-first spec management CLI for software teams",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "specman": "./dist/cli.js"
  },
  "files": [
    "dist",
    "prompts",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "cli",
    "spec",
    "ai",
    "architecture",
    "documentation",
    "adr",
    "domain-rules",
    "specs",
    "cursor",
    "copilot",
    "claude",
    "codex",
    "ai-coding"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhducmata/specman.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "glob": "^11.0.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
