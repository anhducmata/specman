#!/usr/bin/env bash
# Commander CLI
# Usage: commander <command> [subcommand] [args...]

set -e

COMMANDER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$COMMANDER_DIR/scripts/lib/ids.sh"

# current-session pointer lives in the user's project .claude/ dir (where the hook fires)
# Fall back to COMMANDER_DIR if not in a project
if [[ -f "$(pwd)/.claude/current-session" || -d "$(pwd)/.claude" ]]; then
  CURRENT_SESSION_FILE="$(pwd)/.claude/current-session"
else
  CURRENT_SESSION_FILE="$COMMANDER_DIR/.claude/current-session"
fi

# ─── Helpers ──────────────────────────────────────────────────────────────────

die() { echo "error: $*" >&2; exit 1; }

git_commit() {
  local msg="$1"; shift
  cd "$COMMANDER_DIR"
  git add "$@" 2>/dev/null || true
  git diff --cached --quiet || git commit -m "$msg"
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_init() {
  local force=0
  [[ "${1:-}" == "--force" ]] && force=1

  # init runs in the USER'S PROJECT directory, not in commander itself
  local project_dir
  project_dir="$(pwd)"

  # Detect project name from git remote, then folder name
  local project_name
  project_name=$(git -C "$project_dir" remote get-url origin 2>/dev/null \
    | sed 's/.*[:/]\([^/]*\)\.git$/\1/' \
    | sed 's/.*[:/]\([^/]*\)$/\1/' \
    || true)
  [[ -z "$project_name" ]] && project_name=$(basename "$project_dir")

  echo "Initializing Commander for project: $project_name"
  echo "  Project dir : $project_dir"
  echo "  Commander KB: $COMMANDER_DIR"
  echo ""

  # ── 1. Create project folder in KB ──────────────────────────────────────────
  local proj_dir="$COMMANDER_DIR/projects/$project_name"
  if [[ ! -d "$proj_dir" ]]; then
    mkdir -p "$proj_dir"
    # Scaffold empty project files
    cat > "$proj_dir/overview.md" << OVERVIEW
# $project_name — Overview

**Language:**
**Purpose:**

## What It Does

## Key APIs / Entry Points

## Tech Stack
OVERVIEW

    cat > "$proj_dir/gotchas.md" << GOTCHAS
# $project_name — Gotchas

Known sharp edges and non-obvious behaviors.
Add an entry any time something surprises you.

---

_(no gotchas recorded yet)_
GOTCHAS

    cat > "$proj_dir/architecture.md" << ARCH
# $project_name — Architecture

## Core Design

## Key Decisions

## Request / Data Flow
ARCH

    cat > "$proj_dir/open-questions.md" << OQ
# $project_name — Open Questions

Unresolved design problems. Remove when resolved (move answer to architecture.md).

---

_(no open questions yet)_
OQ

    # Commit new project folder to commander KB
    git_commit "project: init $project_name" \
      "$proj_dir/overview.md" \
      "$proj_dir/gotchas.md" \
      "$proj_dir/architecture.md" \
      "$proj_dir/open-questions.md"

    echo "  ✓ Created ~/.commander/projects/$project_name/"
  else
    echo "  ✓ Project already exists in KB: projects/$project_name/"
  fi

  # ── 2. CLAUDE.md — create or inject into existing ───────────────────────────
  local claude_md="$project_dir/CLAUDE.md"
  local commander_block
  commander_block=$(cat << BLOCK
<!-- commander:begin -->
## Commander KB — Bootstrap

You have a Commander knowledge base at \`$COMMANDER_DIR\`.
Load it at the start of every session using the protocol below.

### Phase 1 — Always Load (Tier 1, ~3K tokens) — CACHE THIS PREFIX

Read these files from \`$COMMANDER_DIR\`:
- \`identity/constitution.md\`
- \`identity/decision-heuristics.md\`
- \`identity/constraints.md\`

Place a prompt cache breakpoint after these three files.
**Cost impact: 90% reduction on Tier 1 tokens across repeated sessions.**

### Phase 2 — Retrieve by Project (Tier 2, ≤ 3 files)

Current project: \`$project_name\`

Always read: \`projects/$project_name/gotchas.md\`
If unfamiliar: \`projects/$project_name/overview.md\`, \`architecture.md\`
For decisions: top-2 \`decisions/DEC-NNN--*.md\` by tag match

### Phase 3 — Recent Sessions (Tier 3, ≤ 3 sessions)

Read \`meta/session-index.md\`, filter by \`$project_name\` + last 30 days, load top-3.
Score: \`0.6×relevance + 0.25×recency + 0.15×importance\` — total ≤8K tokens.

### Session Workflow

\`\`\`bash
commander session new <slug> $project_name   # start
commander session end                         # end (Stop hook auto-runs on Claude exit)
commander decision new <slug> $project_name  # log decision
commander feedback new <slug>                 # log outcome
\`\`\`
<!-- commander:end -->
BLOCK
)

  if [[ ! -f "$claude_md" ]]; then
    # No CLAUDE.md — create fresh
    printf "# %s\n\n%s\n" "$project_name" "$commander_block" > "$claude_md"
    echo "  ✓ CLAUDE.md created → $claude_md"
  elif grep -q "commander:begin" "$claude_md"; then
    if [[ $force -eq 1 ]]; then
      # Replace existing commander block
      perl -i -0777 -pe 's/<!-- commander:begin -->.*?<!-- commander:end -->//s' "$claude_md"
      printf "\n%s\n" "$commander_block" >> "$claude_md"
      echo "  ✓ CLAUDE.md commander block updated (--force)"
    else
      echo "  ✓ CLAUDE.md already has commander block (use --force to update)"
    fi
  else
    # CLAUDE.md exists but no commander block — append it
    printf "\n%s\n" "$commander_block" >> "$claude_md"
    echo "  ✓ CLAUDE.md exists — commander block appended"
  fi

  # ── 3. .claude/settings.json — create or merge Stop hook ────────────────────
  local settings_dir="$project_dir/.claude"
  local settings="$settings_dir/settings.json"
  mkdir -p "$settings_dir"

  local hook_cmd="bash $COMMANDER_DIR/scripts/hooks/on-stop.sh"

  if [[ ! -f "$settings" ]]; then
    # No settings.json — create fresh
    cat > "$settings" << JSON
{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$hook_cmd"
          }
        ]
      }
    ]
  }
}
JSON
    echo "  ✓ .claude/settings.json created (Stop hook wired)"
  elif grep -q "on-stop.sh" "$settings"; then
    if [[ $force -eq 1 ]]; then
      # Update the path in case commander moved
      sed -i '' "s|bash .*/on-stop.sh|$hook_cmd|g" "$settings"
      echo "  ✓ .claude/settings.json Stop hook path updated (--force)"
    else
      echo "  ✓ .claude/settings.json already has Stop hook (use --force to update path)"
    fi
  else
    # settings.json exists but no Stop hook — inject into existing hooks or add hooks key
    if grep -q '"Stop"' "$settings"; then
      # Stop key exists, append our hook into it
      python3 - "$settings" "$hook_cmd" << 'PY'
import sys, json
path, cmd = sys.argv[1], sys.argv[2]
with open(path) as f: data = json.load(f)
data.setdefault("hooks", {}).setdefault("Stop", [])
data["hooks"]["Stop"].append({"matcher": "", "hooks": [{"type": "command", "command": cmd}]})
with open(path, "w") as f: json.dump(data, f, indent=2)
PY
      echo "  ✓ .claude/settings.json — Stop hook appended to existing hooks"
    else
      # No Stop key — add it via Python
      python3 - "$settings" "$hook_cmd" << 'PY'
import sys, json
path, cmd = sys.argv[1], sys.argv[2]
with open(path) as f: data = json.load(f)
data.setdefault("hooks", {})["Stop"] = [{"matcher": "", "hooks": [{"type": "command", "command": cmd}]}]
with open(path, "w") as f: json.dump(data, f, indent=2)
PY
      echo "  ✓ .claude/settings.json — Stop hook added"
    fi
  fi

  # ── 4. Make commander scripts executable ────────────────────────────────────
  chmod +x "$COMMANDER_DIR/commander"
  chmod +x "$COMMANDER_DIR/scripts/hooks/on-stop.sh"
  chmod +x "$COMMANDER_DIR/scripts/log-session.sh"
  chmod +x "$COMMANDER_DIR/scripts/compress-session.sh"

  echo ""
  echo "Done. Commander is wired into $project_name."
  echo ""
  echo "Next steps:"
  echo "  1. Open this project in Claude Code — CLAUDE.md loads automatically"
  echo "  2. commander session new <what-you're-doing> $project_name"
  echo "  3. Work. Close Claude — session auto-saved by Stop hook."
}

cmd_session_new() {
  local slug="${1:?Usage: commander session new <slug> <project>}"
  local project="${2:?Usage: commander session new <slug> <project>}"

  local proj_dir="$COMMANDER_DIR/projects/$project"
  [[ -d "$proj_dir" ]] || die "Project '$project' not found. Run 'commander init' in that project first."
  mkdir -p "$proj_dir/sessions"

  local nnn date filename filepath
  nnn=$(next_session_id "$project")
  date=$(date +%Y-%m-%d)
  filename="${date}--${nnn}--${slug}.md"
  filepath="$proj_dir/sessions/$filename"

  sed \
    -e "s|YYYY-MM-DD--NNN|${date}--${nnn}|g" \
    -e "s|\"YYYY-MM-DD\"|\"${date}\"|g" \
    -e "s|projects: \[\]|projects: [\"${project}\"]|g" \
    "$COMMANDER_DIR/templates/session.md" > "$filepath"

  echo "$filepath" > "$CURRENT_SESSION_FILE"
  git_commit "session: start $project/${date}--${nnn}--${slug}" "$filepath"

  echo "Session started: projects/$project/sessions/$filename"
  echo "Tip: fill in Context and Goal now, then work."
}

cmd_session_end() {
  local filepath="${1:-}"

  if [[ -z "$filepath" ]]; then
    [[ -f "$CURRENT_SESSION_FILE" ]] || die "No active session. Pass a file path explicitly."
    filepath=$(cat "$CURRENT_SESSION_FILE" | tr -d '[:space:]')
  fi
  [[ -f "$filepath" ]] || die "Session file not found: $filepath"

  sed -i '' 's/status: "in-progress"/status: "completed"/' "$filepath"

  local slug date id title rel_path
  slug=$(basename "$filepath" .md)
  date=$(grep '^date:' "$filepath" | head -1 | sed 's/date: *"\(.*\)"/\1/')
  id=$(grep '^id:' "$filepath" | head -1 | sed 's/id: *"\(.*\)"/\1/')
  title=$(grep '^# Session:' "$filepath" | head -1 | sed 's/# Session: *//')
  rel_path="${filepath#$COMMANDER_DIR/}"

  git_commit "session: complete $slug" "$filepath"

  # Update project-local session index (simple append)
  local proj_dir
  proj_dir="$(dirname "$(dirname "$filepath")")"
  local index="$proj_dir/session-index.md"
  if [[ ! -f "$index" ]]; then
    printf "# Session Index\n\n| ID | Date | Status | Title | File |\n|---|---|---|---|---|\n" > "$index"
  fi
  if ! grep -q "$id" "$index"; then
    echo "| $id | $date | completed | ${title:-untitled} | $rel_path |" >> "$index"
    git_commit "index: update $proj_dir/session-index" "$index"
  fi

  rm -f "$CURRENT_SESSION_FILE"
  echo "Session completed: $rel_path"
  echo "Tip: run 'commander compress $filepath' to summarize the body."
}

cmd_decision_new() {
  local slug="${1:?Usage: commander decision new <slug> <project>}"
  local project="${2:?Usage: commander decision new <slug> <project>}"

  local proj_dir="$COMMANDER_DIR/projects/$project"
  [[ -d "$proj_dir" ]] || die "Project '$project' not found. Run 'commander init' in that project first."
  mkdir -p "$proj_dir/decisions"

  local dec_id date filename filepath
  dec_id=$(next_decision_id "$project")
  date=$(date +%Y-%m-%d)
  filename="${dec_id}--${slug}.md"
  filepath="$proj_dir/decisions/$filename"

  sed \
    -e "s|DEC-NNN|${dec_id}|g" \
    -e "s|\"YYYY-MM-DD\"|\"${date}\"|g" \
    -e "s|projects: \[\]|projects: [\"${project}\"]|g" \
    "$COMMANDER_DIR/templates/decision.md" > "$filepath"

  git_commit "decision: $project/${dec_id}--${slug}" "$filepath"

  echo "Decision created: projects/$project/decisions/$filename"
  echo "Fill in Context, Options, Decision, Rationale."
}

cmd_feedback_new() {
  local slug="${1:?Usage: commander feedback new <slug> <project>}"
  local project="${2:?Usage: commander feedback new <slug> <project>}"

  local proj_dir="$COMMANDER_DIR/projects/$project"
  [[ -d "$proj_dir" ]] || die "Project '$project' not found. Run 'commander init' in that project first."
  mkdir -p "$proj_dir/feedback"

  local fb_id date filename filepath
  fb_id=$(next_feedback_id "$project")
  date=$(date +%Y-%m-%d)
  filename="${fb_id}--${slug}.md"
  filepath="$proj_dir/feedback/$filename"

  sed \
    -e "s|FB-NNN|${fb_id}|g" \
    -e "s|\"YYYY-MM-DD\"|\"${date}\"|g" \
    "$COMMANDER_DIR/templates/feedback.md" > "$filepath"

  git_commit "feedback: $project/${fb_id}--${slug}" "$filepath"

  echo "Feedback created: projects/$project/feedback/$filename"
  echo "Fill in What Was Expected, What Actually Happened, Lessons."
}

cmd_compress() {
  local filepath="${1:-}"
  if [[ -z "$filepath" && -f "$CURRENT_SESSION_FILE" ]]; then
    filepath=$(cat "$CURRENT_SESSION_FILE" | tr -d '[:space:]')
  fi
  [[ -n "$filepath" ]] || die "No active session and no file specified."
  [[ -f "$filepath" ]] || die "File not found: $filepath"

  echo ""
  echo "──────────────────────────────────────────────────"
  echo "Paste this into Claude to compress the session:"
  echo "──────────────────────────────────────────────────"
  echo ""
  echo "Compress the following session log body to ≤200 tokens."
  echo "Keep the frontmatter (---...---) exactly as-is."
  echo "Replace everything after the frontmatter with:"
  echo ""
  echo "  ## Summary (compressed)"
  echo "  - Goal: [one sentence]"
  echo "  - Key decisions: [DEC refs or inline]"
  echo "  - Outcome: [positive/negative/mixed + one sentence]"
  echo "  - Lessons: [1–2 bullets]"
  echo "  - _Full reasoning trace in git history._"
  echo ""
  echo "Session file contents:"
  echo "──────────────────────────────────────────────────"
  cat "$filepath"
  echo ""
  echo "──────────────────────────────────────────────────"
}

cmd_eject() {
  local project_dir
  project_dir="$(pwd)"
  local claude_md="$project_dir/CLAUDE.md"
  local settings="$project_dir/.claude/settings.json"
  local changed=0

  echo "Ejecting Commander from: $project_dir"
  echo ""

  # ── 1. Remove commander block from CLAUDE.md ──────────────────────────────
  if [[ -f "$claude_md" ]]; then
    if grep -q "commander:begin" "$claude_md"; then
      perl -i -0777 -pe 's/\n?<!-- commander:begin -->.*?<!-- commander:end -->\n?//s' "$claude_md"
      # Clean up blank lines left at end of file
      perl -i -pe 'chomp if eof' "$claude_md"
      echo "  ✓ Commander block removed from CLAUDE.md"
      # If file is now empty or only whitespace, remove it
      if [[ ! -s "$claude_md" ]] || ! grep -q '[^[:space:]]' "$claude_md"; then
        rm -f "$claude_md"
        echo "  ✓ CLAUDE.md was empty after removal — deleted"
      fi
      changed=1
    else
      echo "  — CLAUDE.md has no commander block, skipping"
    fi
  else
    echo "  — No CLAUDE.md found"
  fi

  # ── 2. Remove Stop hook from .claude/settings.json ────────────────────────
  if [[ -f "$settings" ]]; then
    if grep -q "on-stop.sh" "$settings"; then
      python3 - "$settings" << 'PY'
import sys, json

path = sys.argv[1]
with open(path) as f:
    data = json.load(f)

hooks = data.get("hooks", {})
stop_hooks = hooks.get("Stop", [])

# Remove only commander's hook entries
stop_hooks = [h for h in stop_hooks
              if not any("on-stop.sh" in str(step.get("command",""))
                         for step in h.get("hooks", []))]

if stop_hooks:
    data["hooks"]["Stop"] = stop_hooks
else:
    del data["hooks"]["Stop"]

# Remove empty hooks key
if not data.get("hooks"):
    del data["hooks"]

# Write back, or delete if settings is now empty/trivial
if data and data != {}:
    with open(path, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")
else:
    import os; os.remove(path)
PY
      # Check if file was deleted by python script
      if [[ -f "$settings" ]]; then
        echo "  ✓ Stop hook removed from .claude/settings.json"
      else
        echo "  ✓ .claude/settings.json deleted (was only commander's hook)"
      fi
      # Remove .claude/ dir if now empty
      rmdir "$project_dir/.claude" 2>/dev/null && echo "  ✓ .claude/ dir removed (was empty)" || true
      changed=1
    else
      echo "  — .claude/settings.json has no commander hook, skipping"
    fi
  else
    echo "  — No .claude/settings.json found"
  fi

  # ── 3. Clear active session pointer if in this project ────────────────────
  if [[ -f "$CURRENT_SESSION_FILE" ]]; then
    rm -f "$CURRENT_SESSION_FILE"
    echo "  ✓ Active session pointer cleared"
    changed=1
  fi

  echo ""
  if [[ $changed -eq 1 ]]; then
    echo "Commander removed from this project."
    echo "Your knowledge base at $COMMANDER_DIR is untouched."
    echo "Run 'commander init' anytime to re-wire this project."
  else
    echo "Nothing to remove — commander was not wired into this project."
  fi
}

cmd_status() {
  echo "Commander KB — $(git -C "$COMMANDER_DIR" log --oneline -1 2>/dev/null || echo 'no commits')"
  echo ""
  if [[ -f "$CURRENT_SESSION_FILE" ]]; then
    local f
    f=$(cat "$CURRENT_SESSION_FILE" | tr -d '[:space:]')
    echo "Active session: $f"
  else
    echo "Active session: none"
  fi
  echo ""
  echo "Projects:"
  for proj in "$COMMANDER_DIR/projects"/*/; do
    [[ "$(basename "$proj")" == "_template" ]] && continue
    local name sessions decisions feedback
    name=$(basename "$proj")
    sessions=$(find "$proj/sessions" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
    decisions=$(find "$proj/decisions" -name 'DEC-*.md' 2>/dev/null | wc -l | tr -d ' ')
    feedback=$(find "$proj/feedback" -name 'FB-*.md' 2>/dev/null | wc -l | tr -d ' ')
    printf "  %-30s  sessions:%-4s decisions:%-4s feedback:%s\n" "$name" "$sessions" "$decisions" "$feedback"
  done
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  init)
    cmd_init "$@"
    ;;
  session)
    SUBCMD="${1:-}"; shift 2>/dev/null || true
    case "$SUBCMD" in
      new) cmd_session_new "$@" ;;
      end) cmd_session_end "$@" ;;
      *) echo "Usage: commander session <new|end>" >&2; exit 1 ;;
    esac
    ;;
  decision)
    SUBCMD="${1:-}"; shift 2>/dev/null || true
    case "$SUBCMD" in
      new) cmd_decision_new "$@" ;;
      *) echo "Usage: commander decision new <slug> <project>" >&2; exit 1 ;;
    esac
    ;;
  feedback)
    SUBCMD="${1:-}"; shift 2>/dev/null || true
    case "$SUBCMD" in
      new) cmd_feedback_new "$@" ;;
      *) echo "Usage: commander feedback new <slug> <project>" >&2; exit 1 ;;
    esac
    ;;
  compress)
    cmd_compress "$@"
    ;;
  status)
    cmd_status
    ;;
  eject)
    cmd_eject "$@"
    ;;
  help|--help|-h)
    cat << 'HELP'
Commander — AI knowledge base CLI

Usage:
  commander init                              Wire commander into current project
  commander eject                             Remove commander from current project
  commander session new <slug> [proj...]      Start a session
  commander session end [file]                End active session
  commander decision new <slug> [proj...]     Create a decision record (DEC-NNN)
  commander feedback new <slug>               Create a feedback record (FB-NNN)
  commander compress [file]                   Print compression prompt for a session
  commander status                            Show KB status

Examples:
  commander init
  commander eject
  commander session new fix-cache-bug permission-service
  commander session end
  commander decision new use-versioned-keys permission-service
  commander feedback new cache-fix-worked permission-service
  commander status
HELP
    ;;
  *)
    echo "Unknown command: $CMD. Run 'commander help'." >&2
    exit 1
    ;;
esac
